# Copy this file to .env.local (gitignored) and fill in real values.

# Backend API base URL — used by the frontend to reach the ASP.NET Core API.
# Local dev: backend runs on http://localhost:5132 (see ChurchManagement_Backend/Properties/launchSettings.json).
NEXT_PUBLIC_API_BASE=http://localhost:5132

# ---- Auth0 (current; will be replaced in Phase 4) ----
# AUTH0_SECRET is a 32-byte random string used to sign cookies.
# Generate with: openssl rand -base64 32
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ---- Microsoft Entra External ID (used after Phase 4 cutover; ignore until then) ----
# AUTH_SECRET=<openssl rand -base64 32>
# AUTH_MICROSOFT_ENTRA_ID_ID=<spa-app-client-id>
# AUTH_MICROSOFT_ENTRA_ID_SECRET=<spa-app-client-secret>
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://<tenant-subdomain>.ciamlogin.com/<tenant-id>/v2.0
# API_SCOPE=api://<api-app-client-id>/access_as_user
